# Telegram — get from @BotFather
TELEGRAM_BOT_API_KEY=
# Secret token for webhook validation (you choose this — any random string)
TELEGRAM_SECRET_TOKEN=

# Google Sheets — from service account JSON key
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# Google Gemini — get from aistudio.google.com
# Used by @ai-sdk/google provider
GEMINI_API_KEY=
